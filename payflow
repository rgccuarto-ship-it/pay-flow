                <button class="chat-close" onclick="toggleChat()">&times;</button>
            </div>
            <div class="chat-messages" id="chatMessages">
                <div class="message bot">
                    <div class="message-content">¡Hola! Soy el asistente de PayFlow. ¿Cómo puedo ayudarte hoy?</div>
                </div>
            </div>
            <div class="chat-input-area">
                <input type="text" class="chat-input" id="chatInput" placeholder="Escribe tu mensaje..." onkeypress="handleChatKeypress(event)">
                <button class="chat-send" onclick="sendChatMessage()">➤</button>
            </div>
        </div>
    </div>

    <script>
        // ========== FORMULARIO DE CONTACTO ==========
        document.getElementById('contactForm').addEventListener('submit', function(e) {
            e.preventDefault();

            const nombre = document.getElementById('nombre').value.trim();
            const email = document.getElementById('email').value.trim();
            const empresa = document.getElementById('empresa').value.trim();
            const telefono = document.getElementById('telefono').value.trim();
            const asunto = document.getElementById('asunto').value.trim();
            const mensaje = document.getElementById('mensaje').value.trim();

            // Validación básica
            if (!nombre || !email || !asunto || !mensaje) {
                showFormMessage('Por favor, completa todos los campos requeridos', 'error');
                return;
            }

            // Validar email
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(email)) {
                showFormMessage('Por favor, ingresa un email válido', 'error');
                return;
            }

            // Simular envío (en producción, enviar a servidor)
            const formData = {
                nombre,
                email,
                empresa,
                telefono,
                asunto,
                mensaje,
                fecha: new Date().toLocaleString('es-ES')
            };

            console.log('Datos del formulario:', formData);

            // Mostrar mensaje de éxito
            showFormMessage('✓ ¡Mensaje enviado exitosamente! Te contactaremos en breve.', 'success');

            // Limpiar formulario
            document.getElementById('contactForm').reset();

            // Guardar en localStorage para demostración
            const messages = JSON.parse(localStorage.getItem('contactMessages') || '[]');
            messages.push(formData);
            localStorage.setItem('contactMessages', JSON.stringify(messages));

            // Ocultar mensaje después de 5 segundos
            setTimeout(() => {
                document.getElementById('formMessage').style.display = 'none';
            }, 5000);
        });

        function showFormMessage(message, type) {
            const messageEl = document.getElementById('formMessage');
            messageEl.textContent = message;
            messageEl.className = `form-message ${type}`;
            messageEl.style.display = 'block';
        }

        // ========== CHAT EN VIVO ==========
        const chatResponses = {
            default: '¿Cómo puedo ayudarte? Pregúntame sobre nuestros servicios, precios, seguridad o planes.',
            hola: 'Hola, ¿cómo estás? Estoy aquí para resolver tus dudas. ¿En qué puedo ayudarte?',
            precio: 'Ofrecemos planes desde $0 (Starter) hasta Enterprise personalizado. ¿Te gustaría conocer más detalles?',
            seguridad: 'PayFlow tiene certificación PCI-DSS Level 1, encriptación de 256 bits y monitoreo 24/7.',
            pago: 'Procesamos pagos en 150+ monedas con confirmación instantánea. Nuestro sistema detecta fraude automáticamente.',
            api: 'Nuestra API es muy simple de integrar. Te puedo enviar la documentación técnica si deseas.',
            soporte: 'Tenemos soporte 24/7 disponible. ¿Necesitas ayuda con algo específico?',
            gracias: 'De nada, es un placer ayudarte. ¿Hay algo más en lo que pueda asistirte?',
            hasta: 'Hasta luego, gracias por contactarnos. ¡Vuelve pronto!',
            hola_contacto: 'Gracias por llenar el formulario de contacto. Nos pondremos en contacto pronto. ¿Hay algo más que pueda hacer por ti ahora?'
        };

        function toggleChat() {
            const chatBox = document.getElementById('chatBox');
            chatBox.classList.toggle('active');
            if (chatBox.classList.contains('active')) {
                document.getElementById('chatInput').focus();
            }
        }

        function openChat() {
            document.getElementById('chatBox').classList.add('active');
            document.getElementById('chatInput').focus();
        }

        function sendChatMessage() {
            const input = document.getElementById('chatInput');
            const message = input.value.trim();

            if (!message) return;

            // Agregar mensaje del usuario
            addChatMessage(message, 'user');
            input.value = '';

            // Simular respuesta del bot
            setTimeout(() => {
                const response = getBotResponse(message);
                addChatMessage(response, 'bot');
            }, 500);
        }

        function handleChatKeypress(event) {
            if (event.key === 'Enter') {
                sendChatMessage();
            }
        }

        function addChatMessage(text, sender) {
            const messagesDiv = document.getElementById('chatMessages');
            const messageDiv = document.createElement('div');
            messageDiv.className = `message ${sender}`;
            messageDiv.innerHTML = `<div class="message-content">${text}</div>`;
            messagesDiv.appendChild(messageDiv);
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        }

        function getBotResponse(userMessage) {
            const message = userMessage.toLowerCase();

            // Palabras clave para respuestas
            if (message.includes('hola') || message.includes('hi') || message.includes('buenos')) {
                return chatResponses.hola;
            } else if (message.includes('precio') || message.includes('costo') || message.includes('plan')) {
                return chatResponses.precio;
            } else if (message.includes('segur') || message.includes('protección') || message.includes('fraude')) {
                return chatResponses.seguridad;
            } else if (message.includes('pago') || message.includes('transacc') || message.includes('proceso')) {
                return chatResponses.pago;
            } else if (message.includes('api') || message.includes('integr') || message.includes('código')) {
                return chatResponses.api;
            } else if (message.includes('soport') || message.includes('ayuda') || message.includes('problema')) {
                return chatResponses.soporte;
            } else if (message.includes('grac') || message.includes('thanks')) {
                return chatResponses.gracias;
            } else if (message.includes('adiós') || message.includes('bye') || message.includes('hasta')) {
                return chatResponses.hasta;
            } else {
                return chatResponses.default;
            }
        }

        // ========== TABS DE LICENCIA ==========
        function switchLicenseTab(index) {
            const contents = document.querySelectorAll('.license-content');
            const tabs = document.querySelectorAll('.license-tab');

            contents.forEach(c => c.classList.remove('active'));
            tabs.forEach(t => t.classList.remove('active'));

            contents[index].classList.add('active');
            tabs[index].classList.add('active');
        }

        // ========== FUNCIONES AUXILIARES ==========
        function scrollToSection(sectionId) {
            const element = document.getElementById(sectionId);
            if (element) {
                element.scrollIntoView({ behavior: 'smooth' });
            }
        }

        function selectPlan(planName) {
            alert(`¡Excelente! Has seleccionado el plan ${planName}. Te redirigiremos al proceso de registro.`);
            scrollToSection('contacto');
        }

        // Enviar mensaje de bienvenida cuando se cargue la página
        window.addEventListener('load', function() {
            console.log('Página cargada. PayFlow listo para servir.');
        });

        // Animaciones en scroll
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -100px 0px'
        };

        const observer = new IntersectionObserver(function(entries) {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0)';
                }
            });
        }, observerOptions);

        document.querySelectorAll('.feature-card, .service-card').forEach(card => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';
            card.style.transition = 'all 0.6s ease';
            observer.observe(card);
        });

        // Efecto parallax en hero
        window.addEventListener('scroll', function() {
            const hero = document.querySelector('.hero');
            if (hero) {
                hero.style.transform = 'translateY(' + (window.scrollY * 0.5) + 'px)';
            }
        });
    </script>
